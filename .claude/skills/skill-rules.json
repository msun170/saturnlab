{
    "version": "1.0",
    "description": "Skill activation triggers for Saturn notebook app (Tauri + Rust + React)",
    "skills": {
        "skill-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-skill for creating and managing Claude Code skills",
            "promptTriggers": {
                "keywords": [
                    "create skill",
                    "add skill",
                    "skill system",
                    "skill triggers",
                    "skill-rules.json",
                    "hook system"
                ],
                "intentPatterns": [
                    "(create|add|modify|build).*?skill",
                    "skill.*?(work|trigger|activate|system)"
                ]
            }
        },
        "saturn-tauri-rust-guidelines": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Tauri v2 + Rust + React development guidelines for Saturn. Covers kernel management, ZMQ protocol, memory tooling, output rendering, Tauri IPC, .ipynb format, and CodeMirror integration.",
            "promptTriggers": {
                "keywords": [
                    "component",
                    "cell",
                    "notebook",
                    "kernel",
                    "ZMQ",
                    "zeromq",
                    "execute",
                    "output",
                    "render",
                    "memory",
                    "variable inspector",
                    "RAM",
                    "tauri",
                    "rust",
                    "IPC",
                    "command",
                    "ipynb",
                    "CodeMirror",
                    "markdown cell",
                    "code cell",
                    "toolbar",
                    "sidebar",
                    "file browser",
                    "terminal",
                    "theme",
                    "settings",
                    "export",
                    "plotly",
                    "bokeh",
                    "altair",
                    "virtual scroll",
                    "autocomplete",
                    "kernel discovery"
                ],
                "intentPatterns": [
                    "(create|add|build|implement|write|fix|update|modify|refactor).*?(component|cell|output|renderer|panel|toolbar|sidebar|hook|command)",
                    "(how to|best practice).*?(tauri|rust|kernel|zmq|memory|output|notebook)",
                    "(render|display|show).*?(output|image|plot|table|error|latex)",
                    "(manage|monitor|track|inspect).*?(memory|RAM|variable|kernel)",
                    "(send|receive|handle).*?(message|request|reply|execution)",
                    "(open|save|read|write|parse).*?(notebook|ipynb|cell)",
                    "(start|stop|restart|interrupt|spawn|kill).*?kernel"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "src-tauri/src/**/*.rs",
                    "src/components/**/*.tsx",
                    "src/components/**/*.ts",
                    "src/hooks/**/*.ts",
                    "src/lib/**/*.ts",
                    "src/types/**/*.ts",
                    "src/themes/**/*.css"
                ],
                "pathExclusions": [
                    "**/*.test.tsx",
                    "**/*.test.ts",
                    "**/*.spec.tsx",
                    "**/*.spec.ts",
                    "**/node_modules/**",
                    "**/target/**"
                ]
            }
        }
    }
}
